<!DOCTYPE html>
<html lang="pt-BR">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Clinica Meraki</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">
    <link href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.1/font/bootstrap-icons.css" rel="stylesheet">
    <link rel="stylesheet" href="/public/blog.css">
</head>
<body>
    <div id="principal">

  <!-- Navbar -->
  <nav class="navbar navbar-expand-lg navbar-dark fixed-top">
    <div class="container">
      <a class="navbar-brand" href="#">
        <img src="/imagens/LogoDourada.png" alt="Logo Meraki" style="height: 60px;">
      </a>
      <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#navbarNav">
        <span class="navbar-toggler-icon"></span>
      </button>

      <div class="collapse navbar-collapse justify-content-center" id="navbarNav">
        <ul class="navbar-nav">
          <li class="nav-item"><a class="nav-link" href="/app/views/home.ejs">Home</a></li>

          <li class="nav-item dropdown">
            <a class="nav-link dropdown-toggle" href="#" id="servicosDropdown" role="button" data-bs-toggle="dropdown" aria-expanded="false">
              Procedimentos
            </a>
            <ul class="dropdown-menu" aria-labelledby="servicosDropdown">
              <li><a class="dropdown-item" href="/app/views/Proc_Corporal.ejs">Corporais</a></li>
              <li><a class="dropdown-item" href="/app/views/Proc_Facial.ejs">Faciais</a></li>
              <li><a class="dropdown-item" href="/app/views/Proc_Capilares.ejs">Capilares</a></li>
            </ul>
          </li>

          <li class="nav-item"><a class="nav-link" href="/app/views/Profissionais.html">Profissionais</a></li>
          <li class="nav-item"><a class="nav-link" href="/app/views/blog.html">Blog</a></li>
          <li class="nav-item"><a class="nav-link" href="/app/views/Outros_Servicos.html">Outros Serviços</a></li>
         
        </ul>
      </div>

      <div class="social-icons d-none d-lg-flex">
        <a href="https://www.instagram.com/clinicamerakicampinas/?hl=pt-br"><i class="bi bi-instagram mx-2"></i></a>
        <a href="https://api.whatsapp.com/send/?phone=5519971462301&text&type=phone_number&app_absent=0"><i class="bi bi-whatsapp mx-2"></i></a>
        <a href="https://www.facebook.com/Clinica.Meraki.estetica.e.saude/"><i class="bi bi-facebook mx-2"></i></a>
      </div>
    </div>
  </nav>

  <div class="principal">

     <!-- Imagem  -->
  <img id="capa-img" src="/imagens/Principal.jpg" alt="Imagem de capa da página de profissionais">
  <div class="texto">
    <span id="capa-titulo"></span><br>
    <p id="capa-subtitulo">Blog</p>
  </div>
</div>


<!-- Post do blog  -->
<% for (let i = 0; i < blog.length; i++) { %>

<div class="blog-card">

  <!-- Imagem do post -->
  <div class="blog-img">
    <img src="<%= blog[i].imagem_post %>" alt="Imagem do post">
  </div>

  <!-- Texto -->
  <div class="blog-text">
    <h2><%= blog[i].titulo_post %></h2>

    <p>
      <%= blog[i].descricao_post %>
    </p>

    <!-- Lista de benefícios -->
    <ul>
      <% let beneficios = blog[i].beneficios.split(','); %>
      <% for (let j = 0; j < beneficios.length; j++) { %>
        <li><%= beneficios[j] %></li>
      <% } %>
    </ul>
  </div>

</div>

<% } %>



<!-- Rodapé -->
<section class="contatos" role="contentinfo" aria-label="Informações de contato">

  <img src="/imagens/logo.png" alt="Logo da Clínica Meraki" class="logo-secao">

  <div class="info">
    
    <p>
      <i class="bi bi-geo-alt-fill"></i>
      Av. Wellman Galvão de França Rangel, 1295 - Swiss Park, Campinas/SP
    </p>

    <p>
      <i class="fa-solid fa-phone"></i>
      (19) 97146-2301
    </p>

    <p>
      <i class="bi bi-envelope-fill"></i>
      clinicamercampinas.com.br
    </p>

  </div>

  <p class="copy">
    © 2025 Clínica Meraki — Todos os direitos reservados.
  </p>

</section>

<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
</body>
</html>

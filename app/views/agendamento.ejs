<!DOCTYPE html>
<html lang="pt-BR">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">

  <title>Agendamento | Clínica Meraki</title>

  <!-- Bootstrap -->
  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">

  <!-- Ícones -->
  <link href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.1/font/bootstrap-icons.css" rel="stylesheet">

  <!-- CSS -->
  <link href="/home.css" rel="stylesheet">

</head>

<body>

<div id="principal_agend">

  <!-- NAVBAR -->
  <nav class="navbar navbar-expand-lg navbar-dark fixed-top">

    <div class="container">

      <a class="navbar-brand" href="/">
        <img src="/imagens/LogoDourada.png" style="height: 60px;">
      </a>

      <button class="navbar-toggler" type="button"
        data-bs-toggle="collapse"
        data-bs-target="#navbarNav">

        <span class="navbar-toggler-icon"></span>

      </button>

      <div class="collapse navbar-collapse justify-content-center" id="navbarNav">

        <ul class="navbar-nav">

          <li class="nav-item">
            <a class="nav-link" href="/">Home</a>
          </li>

          <li class="nav-item dropdown">

            <a class="nav-link dropdown-toggle"
              data-bs-toggle="dropdown">

              Procedimentos

            </a>

            <ul class="dropdown-menu">

              <li>
                <a class="dropdown-item"
                  href="/procedimentoscorporais">

                  Corporais

                </a>
              </li>

              <li>
                <a class="dropdown-item"
                  href="/procedimentosfaciais">

                  Faciais

                </a>
              </li>

              <li>
                <a class="dropdown-item"
                  href="/procedimentoscapilares">

                  Capilares

                </a>
              </li>

            </ul>

          </li>

          <li class="nav-item">
            <a class="nav-link" href="/profissionais">
              Profissionais
            </a>
          </li>

          <li class="nav-item">
            <a class="nav-link" href="/blog">
              Blog
            </a>
          </li>

          <li class="nav-item">
            <a class="nav-link" href="/outrosservicos">
              Outros Serviços
            </a>
          </li>

        </ul>

      </div>

    </div>

  </nav>

</div>

<!-- CONTAINER -->
<section class="container py-5" style="margin-top: 120px;">

  <h1 class="titulo-descricao">
    Agendamento
    <i class="bi bi-chevron-right"></i>
  </h1>

  <br>

  <div class="row justify-content-center">

    <div class="col-md-8">

      <div class="card shadow p-4">

        <form method="POST" action="/agendamento">

          <!-- NOME -->
          <div class="mb-3">

            <label class="form-label">
              Nome Completo
            </label>

            <input
              type="text"
              name="nome_agendamento"
              class="form-control"
              required
              value="<%= agendamento?.nome_agendamento || '' %>"
            >

          </div>

          <!-- EMAIL -->
          <div class="mb-3">

            <label class="form-label">
              Email
            </label>

            <input
              type="email"
              name="email_agendamento"
              class="form-control"
              required
              value="<%= agendamento?.email_agendamento || '' %>"
            >

          </div>

          <!-- TELEFONE -->
          <div class="mb-3">

            <label class="form-label">
              Telefone
            </label>

            <input
              type="text"
              name="telefone_agendamento"
              class="form-control"
              required
              value="<%= agendamento?.telefone_agendamento || '' %>"
            >

          </div>

          <!-- TIPO -->
          <div class="mb-3">

            <label class="form-label">
              Tipo de Atendimento
            </label>

            <select
              name="tipo"
              class="form-select"
              required
            >

              <option value="">Selecione</option>

              <option value="consulta">Consulta</option>

              <option value="capilar">Capilar</option>

              <option value="facial">Facial</option>

              <option value="corporal">Corporal</option>

              <option value="esmalteria">Esmalteria</option>

            </select>

          </div>

          <!-- DATA -->
          <div class="mb-4">

            <label class="form-label">
              Data Desejada
            </label>

            <input
              type="date"
              name="data_desejada"
              class="form-control"
              required
            >

          </div>

          <!-- BOTÕES -->
          <div class="d-flex gap-3">

            <button
              type="submit"
              class="btn btn-dark w-100"
            >

              Enviar Agendamento

            </button>

            <a
              href="/"
              class="btn btn-outline-dark w-100"
            >

              Cancelar

            </a>

          </div>

        </form>

      </div>

    </div>

  </div>

</section>

<!-- FOOTER -->
<footer id="footer" class="text-center py-4">

  <div class="container">

    <img src="/imagens/LogoDourada.png"
      style="max-width: 180px;">

    <br>

    <p>
      <i class="bi bi-geo-alt-fill"></i>
      Campinas/SP
    </p>

    <p>
      <i class="bi bi-whatsapp"></i>
      (19) 97146-2301
    </p>

    <hr>

    <small>
      © 2025 Clínica Meraki — Todos os direitos reservados.
    </small>

  </div>

</footer>

<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>

</body>
</html>
<!DOCTYPE html>
<html lang="pt-BR">
<head>

  <meta charset="UTF-8">
  <meta name="viewport"
        content="width=device-width, initial-scale=1.0">

  <title>Outros Serviços</title>

  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css"
        rel="stylesheet">

  <link href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.1/font/bootstrap-icons.css"
        rel="stylesheet">

  <link href="/css/style.css" rel="stylesheet">

</head>

<body>

<div id="principal_outrosServicos">

<nav class="navbar navbar-expand-lg fixed-top">

<div class="container">

<a class="navbar-brand" href="/">
<img src="/imagens/LogoDourada.png"
     style="height:60px;">
</a>

<button class="navbar-toggler"
        type="button"
        data-bs-toggle="collapse"
        data-bs-target="#navbarNav">

<span class="navbar-toggler-icon"></span>

</button>

<div class="collapse navbar-collapse justify-content-center"
     id="navbarNav">

<ul class="navbar-nav">

<li class="nav-item">
<a class="nav-link" href="/">Home</a>
</li>

<li class="nav-item dropdown">

<a class="nav-link dropdown-toggle"
   data-bs-toggle="dropdown">

Procedimentos

</a>

<ul class="dropdown-menu">

<li>
<a class="dropdown-item"
href="/procedimentoscorporais">
Corporais
</a>
</li>

<li>
<a class="dropdown-item"
href="/procedimentosfaciais">
Faciais
</a>
</li>

<li>
<a class="dropdown-item"
href="/procedimentoscapilares">
Capilares
</a>
</li>

</ul>

</li>

<li class="nav-item">
<a class="nav-link"
href="/profissionais">
Profissionais
</a>
</li>

<li class="nav-item">
<a class="nav-link"
href="/blog">
Blog
</a>
</li>

<li class="nav-item">
<a class="nav-link"
href="/outrosservicos">
Outros Serviços
</a>
</li>

</ul>

</div>

</div>

</nav>

</div>

<!-- CONTEÚDO -->

<section class="container py-5"
         style="margin-top:100px;">

<h1 class="titulo-descricao">

Outros <span>Serviços</span>

</h1>

<br><br>

<div class="accordion">

<% servicos.forEach((item, i) => { %>

<div class="accordion-item mb-3">

<h2 class="accordion-header">

<button
class="accordion-button <%= i !== 0 ? 'collapsed' : '' %>"
type="button"
data-bs-toggle="collapse"
data-bs-target="#item<%= i %>">

<i class="<%= item.icone_outros %> me-2"></i>

<%= item.titulo_outros %>

</button>

</h2>

<div id="item<%= i %>"
class="accordion-collapse collapse
<%= i === 0 ? 'show' : '' %>">

<div class="accordion-body">

<%- item.descricao_outros %>

</div>

</div>

</div>

<% }) %>

</div>

</section>

<!-- RESULTADOS -->

<section class="container py-5">

<div class="row">

<% antesDepois.forEach(item => { %>

<div class="col-md-4 mb-4">

<div class="card h-100">

<img src="<%= item.imagem_antes_outros %>"
     class="card-img-top">

<div class="card-body text-center">

<h5>
<%= item.titulo_antes_outros %>
</h5>

<p>
<%= item.descricao_antes_outros %>
</p>

</div>

</div>

</div>

<% }) %>

</div>

</section>

<footer id="footer" class="text-center py-4">

  <div class="container">

    <img
      src="/imagens/LogoDourada.png"
      alt="Clínica Meraki"
      style="max-width:180px;">

    <br>
    <br>

    <p>
      <i class="bi bi-geo-alt-fill"></i>
      Av. Wellman Galvão de França Rangel, 1295 - Swiss Park, Campinas/SP
    </p>

    <p>
      <i class="bi bi-whatsapp"></i>
      (19) 97146-2301
    </p>

    <p>
      <i class="bi bi-envelope-fill"></i>
      clinicameraki@campinas.com.br
    </p>

    <hr>

    <small>
      © 2025 Clínica Meraki — Todos os direitos reservados.
    </small>

  </div>

</footer>

<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>

</body>
</html>
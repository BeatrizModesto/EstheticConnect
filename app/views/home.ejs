<!DOCTYPE html>
<html lang="pt-BR">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Clínica Meraki - Estética e Saúde</title>

  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">
  <link href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.1/font/bootstrap-icons.css" rel="stylesheet">

  <link rel="stylesheet" href="/home.css">
</head>
<body>

<div id="principal">
  <!-- Navbar -->
  <nav class="navbar navbar-expand-lg navbar-dark fixed-top">
    <div class="container">
      <a class="navbar-brand" href="/">
        <img src="/imagens/LogoDourada.png" style="height: 60px;">
      </a>

      <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#navbarNav">
        <span class="navbar-toggler-icon"></span>
      </button>

      <div class="collapse navbar-collapse justify-content-center" id="navbarNav">
        <ul class="navbar-nav">
          <li class="nav-item"><a class="nav-link" href="/">Home</a></li>

          <li class="nav-item dropdown">
            <a class="nav-link dropdown-toggle" data-bs-toggle="dropdown">
              Procedimentos
            </a>
            <ul class="dropdown-menu">
              <li><a class="dropdown-item" href="/procedimentoscorporais">Corporais</a></li>
              <li><a class="dropdown-item" href="/procedimentosfaciais">Faciais</a></li>
              <li><a class="dropdown-item" href="/procedimentoscapilares">Capilares</a></li>
            </ul>
          </li>
          <li class="nav-item"><a class="nav-link" href="/outrosservicos">Outros Serviços</a></li>
          <li class="nav-item"><a class="nav-link" href="/profissionais">Profissionais</a></li>
          <li class="nav-item"><a class="nav-link" href="/blog">Blog</a></li>
          <li class="nav-item"><a class="nav-link" href="/login"> | AdminLogin</a></li>
        </ul>
      </div>
    </div>
  </nav>

  <!-- Header -->
  <header class="hero-header">
    <div class="hero-content text-white">
      <h2>CONHEÇA NOSSOS SERVIÇOS</h2>
      <a href="/agendamento" class="btn btn-primary mt-3">Agende uma consulta</a>
    </div>
  </header>
</div>

<!-- DESCRIÇÃO -->
<section class="py-5 container">
  <div class="descricao-wrapper">

    <img src="/imagens/img3.PNG" class="imagem-doutora">

    <div class="texto-descricao">
      <h1>
        Bem-vindo a nossa Clínica <br>
        <span>Meraki!</span>
      </h1>

      <h3>Sobre Nossa Clínica</h3>

      <!-- TEXTO DINÂMICO -->
      <% descricao.forEach(item => { %>
        <p><%= item.texto %></p>
      <% }) %>
    </div>

  </div>
</section>

<h1 class="text-center">
  Excelência em cada <span>Transformação</span>
</h1>

<!-- CAROUSEL DINÂMICO -->
<div id="carouselMeraki" class="carousel slide" data-bs-ride="carousel">
  <div class="carousel-inner">

    <% carousel.forEach((item, index) => { %>
      <div class="carousel-item <%= index === 0 ? 'active' : '' %>">
        <img src="<%= item.imagem %>" class="d-block w-100">
        <div class="carousel-caption">
          <h5><%= item.titulo %></h5>
          <p><%= item.descricao %></p>
        </div>
      </div>
    <% }) %>

  </div>

  <button class="carousel-control-prev" type="button" data-bs-target="#carouselMeraki" data-bs-slide="prev">
    <span class="carousel-control-prev-icon"></span>
  </button>

  <button class="carousel-control-next" type="button" data-bs-target="#carouselMeraki" data-bs-slide="next">
    <span class="carousel-control-next-icon"></span>
  </button>
</div>
<br>
<br>
<br>
<!-- Avaliações -->

  <div class="container text-center">
  <h2 class="mb-4"> <i class="bi bi-chevron-right"></i>A voz de quem confia em nosso <span>cuidado</span><i class="bi bi-chevron-left"></i></h2>  

<div class="row justify-content-center">

    <% avaliacoes.forEach(av => { %>

        <div class="col-md-4 mb-4">

            <div class="card shadow-sm p-4 h-100">

                <h5>
                    <%= "⭐".repeat(av.nota) %>
                </h5>

                <p>
                    "<%= av.texto %>"
                </p>

                <small>
                    - <%= av.nome %>
                </small>

            </div>

        </div>

    <% }) %>

</div>



<!-- FOOTER -->

<!-- Rodapé -->
<footer id="footer" class="text-white py-4">
  <div class="footer-content">
    <iframe 
      src="https://www.google.com/maps/embed?pb=!1m14!1m8!1m3!1d117557.8080762676!2d-47.1559837!3d-22.961954!3m2!1i1024!2i768!4f13.1!3m3!1m2!1s0x94c8cb2029bab5b3%3A0x52c46cd658284e16!2sClinica%20Meraki%20Est%C3%A9tica%20e%20Sa%C3%BAde!5e0!3m2!1spt-BR!2sbr!4v1763127266376!5m2!1spt-BR!2sbr" 
      width="400" height="350"
      style="border:0;" loading="lazy">
    </iframe>
    <div class="footer-info text-center">
       <img src="/imagens/LogoDourada.png" class="footer-logo">
      <p class="mt-3 mb-1"><i class="bi bi-geo-alt-fill"></i> Av. Wellman Galvão de França Rangel, 1295 - Swiss Park, Campinas/SP</p>
      <p class="mb-1"><i class="bi bi-whatsapp"></i> (19) 97146-2301</p>
      <p class="mb-0"><i class="bi bi-envelope-fill"></i> clinicamercampinas.com.br</p>

    </div>
<small>© 2025 Clínica Meraki — Todos os direitos reservados.</small>
  </div>
</footer>


<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
</body>
</html>

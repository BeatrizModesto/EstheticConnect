<!DOCTYPE html>
<html lang="pt-BR">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">

  <title>Procedimentos Capilares | Clínica Meraki</title>

  <!-- Bootstrap -->
  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">

  <!-- Bootstrap Icons -->
  <link href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.1/font/bootstrap-icons.css" rel="stylesheet">

  <!-- CSS -->
  <link href="/css/style.css" rel="stylesheet">
</head>

<body>

<!-- HERO -->
<div id="principal_pcap">

  <!-- NAVBAR -->
  <nav class="navbar navbar-expand-lg fixed-top">

    <div class="container">

      <a class="navbar-brand" href="/">
        <img src="/imagens/LogoDourada.png" alt="Logo Meraki" style="height:60px;">
      </a>

      <button
        class="navbar-toggler"
        type="button"
        data-bs-toggle="collapse"
        data-bs-target="#navbarNav">

        <span class="navbar-toggler-icon"></span>
      </button>

      <div class="collapse navbar-collapse justify-content-center" id="navbarNav">

        <ul class="navbar-nav">

          <li class="nav-item">
            <a class="nav-link" href="/">Home</a>
          </li>

          <li class="nav-item dropdown">

            <a
              class="nav-link dropdown-toggle"
              href="#"
              role="button"
              data-bs-toggle="dropdown">

              Procedimentos
            </a>

            <ul class="dropdown-menu">

              <li>
                <a class="dropdown-item" href="/procedimentoscorporais">
                  Corporais
                </a>
              </li>

              <li>
                <a class="dropdown-item" href="/procedimentosfaciais">
                  Faciais
                </a>
              </li>

              <li>
                <a class="dropdown-item" href="/procedimentoscapilares">
                  Capilares
                </a>
              </li>

            </ul>

          </li>

          <li class="nav-item">
            <a class="nav-link" href="/profissionais">
              Profissionais
            </a>
          </li>

          <li class="nav-item">
            <a class="nav-link" href="/blog">
              Blog
            </a>
          </li>

          <li class="nav-item">
            <a class="nav-link" href="/outrosservicos">
              Outros Serviços
            </a>
          </li>

        </ul>

      </div>

      <!-- Redes sociais -->
      <div class="social-icons d-none d-lg-flex">

        <a href="https://www.instagram.com/clinicamerakicampinas/?hl=pt-br">
          <i class="bi bi-instagram mx-2"></i>
        </a>

        <a href="https://api.whatsapp.com/send/?phone=5519971462301">
          <i class="bi bi-whatsapp mx-2"></i>
        </a>

        <a href="https://www.facebook.com/Clinica.Meraki.estetica.e.saude/">
          <i class="bi bi-facebook mx-2"></i>
        </a>

      </div>

    </div>

  </nav>

</div>

<!-- CONTEÚDO -->
<section class="container py-5" style="margin-top: 100px;">

  <h1 class="titulo-descricao">
    Procedimentos <span>Capilares</span>
  </h1>

  <br>
  <br>

  <!-- ACCORDION -->
  <div class="accordion" id="procedimentosCapilares">

    <% procedimentos.forEach((item, i) => { %>

      <div class="accordion-item mb-3">

        <h2 class="accordion-header">

          <button
            class="accordion-button <%= i !== 0 ? 'collapsed' : '' %>"
            type="button"
            data-bs-toggle="collapse"
            data-bs-target="#item<%= i %>">

            <i class="<%= item.icone_capilar %> me-2"></i>

            <%= item.titulo_capilar %>

          </button>

        </h2>

        <div
          id="item<%= i %>"
          class="accordion-collapse collapse <%= i === 0 ? 'show' : '' %>">

          <div class="accordion-body">

            <%= item.descricao_capilar %>

          </div>

        </div>

      </div>

    <% }) %>

  </div>

</section>

<!-- RESULTADOS -->
<section class="container py-5" id="antesDepois">

  <center>
    <h2 class="titulo-descricao">
      <i class="bi bi-chevron-right"></i>
      Resultados
    </h2>
  </center>

  <br>
  <br>

  <div class="row">

    <% antesDepois.forEach(item => { %>

      <div class="col-md-4 mb-4">

        <div class="card h-100 shadow-sm">

          <img
            src="<%= item.imagem_antes_capilar %>"
            class="card-img-top"
            alt="<%= item.titulo_antes_capilar %>">

          <div class="card-body text-center">

            <h5 class="card-title">
              <%= item.titulo_antes_capilar %>
            </h5>

            <p class="card-text">
              <%= item.descricao_antes_capilar %>
            </p>

          </div>

        </div>

      </div>

    <% }) %>

  </div>

</section>

<!-- FOOTER -->
<footer id="footer" class="text-center py-4">

  <div class="container">

    <img
      src="/imagens/LogoDourada.png"
      alt="Clínica Meraki"
      style="max-width:180px;">

    <br>
    <br>

    <p>
      <i class="bi bi-geo-alt-fill"></i>
      Av. Wellman Galvão de França Rangel, 1295 - Swiss Park, Campinas/SP
    </p>

    <p>
      <i class="bi bi-whatsapp"></i>
      (19) 97146-2301
    </p>

    <p>
      <i class="bi bi-envelope-fill"></i>
      clinicameraki@campinas.com.br
    </p>

    <hr>

    <small>
      © 2025 Clínica Meraki — Todos os direitos reservados.
    </small>

  </div>

</footer>

<!-- Bootstrap -->
<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>

</body>
</html>
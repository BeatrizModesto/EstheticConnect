<!DOCTYPE html>
<html>
<head>

<title>Painel Admin</title>

<link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">

</head>

<body>

<div class="container mt-5">

<h1>Painel Administrativo</h1>

<hr>

<h2>Agendamentos</h2>

<table class="table table-bordered">

<tr>
  <th>Nome</th>
  <th>Email</th>
  <th>Telefone</th>
  <th>Tipo</th>
  <th>Data</th>
  <th>Ações</th>
</tr>

<% agendamentos.forEach(item => { %>

<tr>

<form action="/admin/agendamento/<%= item.id %>/editar" method="POST">

<td>
<input
class="form-control"
name="nome_agendamento"
value="<%= item.nome_agendamento %>">
</td>

<td>
<input
class="form-control"
name="email_agendamento"
value="<%= item.email_agendamento %>">
</td>

<td>
<input
class="form-control"
name="telefone_agendamento"
value="<%= item.telefone_agendamento %>">
</td>

<td>
<input
class="form-control"
name="tipo"
value="<%= item.tipo %>">
</td>

<td>
<input
type="date"
class="form-control"
name="data_desejada"
value="<%= item.data_desejada.toISOString().split('T')[0] %>">
</td>

<td>

<button class="btn btn-success btn-sm">
Salvar
</button>

</form>

<form
action="/admin/agendamento/<%= item.id %>/excluir"
method="POST">

<button class="btn btn-danger btn-sm mt-1">
Excluir
</button>

</form>

</td>

</tr>

<% }) %>

</table>

<hr>

<h2>Dúvidas</h2>

<table class="table table-bordered">

<tr>
  <th>Nome</th>
  <th>Email</th>
  <th>Telefone</th>
  <th>Dúvida</th>
  <th>Ações</th>
</tr>

<% duvidas.forEach(item => { %>

<tr>

<form action="/admin/duvida/<%= item.id %>/editar" method="POST">

<td>
<input
class="form-control"
name="nome_completo"
value="<%= item.nome_completo %>">
</td>

<td>
<input
class="form-control"
name="email"
value="<%= item.email %>">
</td>

<td>
<input
class="form-control"
name="telefone"
value="<%= item.telefone %>">
</td>

<td>
<textarea
class="form-control"
name="duvida"><%= item.duvida %></textarea>
</td>

<td>

<button class="btn btn-success btn-sm">
Salvar
</button>

</form>

<form
action="/admin/duvida/<%= item.id %>/excluir"
method="POST">

<button class="btn btn-danger btn-sm mt-1">
Excluir
</button>

</form>

</td>

</tr>

<% }) %>

</table>

</div>

</body>
</html>
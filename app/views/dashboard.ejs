<!DOCTYPE html>
<html>
<head>

<title>Painel Admin</title>

<link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">
<link rel="stylesheet" href="/dashboard.css">
</head>

<body>

<div class="container mt-5">
<% if (mensagem) { %>

<div class="alert alert-success alert-dismissible fade show">

    <%= mensagem %>

    <button
        type="button"
        class="btn-close"
        data-bs-dismiss="alert">
    </button>

</div>

<% } %>

<div class="topo-dashboard">

    <div class="cabecalho-admin">

        <img
            src="/imagens/LogoDourada.png"
            alt="Logo Meraki"
            class="logo-dashboard"
        >

        <h1 class="titulo-dashboard">
            Painel Administrativo
        </h1>

    </div>

    <a href="/logout" class="btn-sair">
        Sair
    </a>

</div>

<hr>

<h2>Agendamentos</h2>

<table class="table table-bordered">

<tr>
  <th>Nome</th>
  <th>Email</th>
  <th>Telefone</th>
  <th>Tipo</th>
  <th>Data</th>
  <th>Ações</th>
</tr>

<% agendamentos.forEach(item => { %>

<tr>

<form action="/admin/agendamento/<%= item.id %>/editar" method="POST">

<td>
<input
class="form-control"
name="nome_agendamento"
value="<%= item.nome_agendamento %>">
</td>

<td>
<input
class="form-control"
name="email_agendamento"
value="<%= item.email_agendamento %>">
</td>

<td>
<input
class="form-control"
name="telefone_agendamento"
value="<%= item.telefone_agendamento %>">
</td>

<td>
<input
class="form-control"
name="tipo"
value="<%= item.tipo %>">
</td>

<td>
<input
type="date"
class="form-control"
name="data_desejada"
value="<%= item.data_desejada.toISOString().split('T')[0] %>">
</td>

<td>

<button class="btn btn-success btn-sm">
Salvar
</button>

</form>

<form
action="/admin/agendamento/<%= item.id %>/excluir"
method="POST">

<button class="btn btn-danger btn-sm mt-1">
Excluir
</button>

</form>

</td>

</tr>

<% }) %>

</table>

<hr>

<h2>Dúvidas</h2>

<table class="table table-bordered">

<tr>
  <th>Nome</th>
  <th>Email</th>
  <th>Telefone</th>
  <th>Dúvida</th>
  <th>Ações</th>
</tr>

<% duvidas.forEach(item => { %>

<tr>

<form action="/admin/duvida/<%= item.id %>/editar" method="POST">

<td>
<input
class="form-control"
name="nome_completo"
value="<%= item.nome_completo %>">
</td>

<td>
<input
class="form-control"
name="email"
value="<%= item.email %>">
</td>

<td>
<input
class="form-control"
name="telefone"
value="<%= item.telefone %>">
</td>

<td>
<textarea
class="form-control"
name="duvida"><%= item.duvida %></textarea>
</td>

<td>

<button class="btn btn-success btn-sm">
Salvar
</button>

</form>

<form
action="/admin/duvida/<%= item.id %>/excluir"
method="POST">

<button class="btn btn-danger btn-sm mt-1">
Excluir
</button>

</form>

</td>

</tr>

<% }) %>

</table>

</div>

<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>

</body>
</html>

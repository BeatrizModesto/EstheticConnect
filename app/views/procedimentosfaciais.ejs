<!DOCTYPE html>
<html lang="pt-BR">
<head>
  <meta charset="UTF-8">
  <title>Procedimentos Faciais</title>

  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">
  <link href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.1/font/bootstrap-icons.css" rel="stylesheet">

  <!-- CSS CORRIGIDO -->
  <link href="/css/style.css" rel="stylesheet">
</head>

<body>

<div id="principal_pf">

<nav class="navbar navbar-expand-lg fixed-top">
  <div class="container">

    <a class="navbar-brand" href="/">
      <img src="/imagens/LogoDourada.png" style="height:60px;">
    </a>

    <div class="collapse navbar-collapse justify-content-center">
      <ul class="navbar-nav">

        <li class="nav-item"><a class="nav-link" href="/">Home</a></li>

        <li class="nav-item dropdown">
          <a class="nav-link dropdown-toggle" data-bs-toggle="dropdown">Procedimentos</a>
          <ul class="dropdown-menu">
            <li><a class="dropdown-item" href="/procedimentoscorporais">Corporais</a></li>
            <li><a class="dropdown-item" href="/procedimentosfaciais">Faciais</a></li>
            <li><a class="dropdown-item" href="/procedimentoscapilares">Capilares</a></li>
          </ul>
        </li>

        <li class="nav-item"><a class="nav-link" href="/profissionais">Profissionais</a></li>
        <li class="nav-item"><a class="nav-link" href="/blog">Blog</a></li>
        <li class="nav-item"><a class="nav-link" href="/outrosservicos">Outros Serviços</a></li>

      </ul>
    </div>
  </div>
</nav>

</div>

<!-- CONTEÚDO -->
<section class="container py-5" style="margin-top: 100px;">

<h1 class="titulo-descricao">
  Procedimentos <span>Faciais</span>
</h1>

<br>

<div class="accordion" id="procedimentosFaciais">

  <% procedimentos.forEach((item, i) => { %>

    <div class="accordion-item">

      <h2 class="accordion-header">

        <button class="accordion-button <%= i !== 0 ? 'collapsed' : '' %>"
          data-bs-toggle="collapse"
          data-bs-target="#item<%= i %>">

          <i class="<%= item.icone_facial %> me-2"></i>
          <%= item.titulo_facial %>

        </button>

      </h2>

      <div id="item<%= i %>"
        class="accordion-collapse collapse <%= i === 0 ? 'show' : '' %>">

        <div class="accordion-body">
          <%= item.descricao_facial %>
        </div>

      </div>

    </div>

  <% }) %>

</div>

</section>

<!-- ANTES E DEPOIS -->
<section class="container py-5">

<h2 class="titulo-descricao text-center">
Resultados
</h2>

<br><br>

<div class="row">

  <% antesDepois.forEach(item => { %>

    <div class="col-md-4 mb-4">

      <div class="card">

        <img src="<%= item.imagem_antes_facial %>" class="card-img-top">

        <div class="card-body text-center">
          <h5><%= item.titulo_antes_facial %></h5>
          <p><%= item.descricao_antes_facial %></p>
        </div>

      </div>

    </div>

  <% }) %>

</div>

</section>

<footer id="footer" class="text-center py-4">
  <img src="/imagens/LogoDourada.png" style="max-width:180px;">
  <p>Campinas/SP</p>
</footer>

<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>

</body>
</html>